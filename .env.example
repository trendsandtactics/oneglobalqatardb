# ── MySQL Database ───────────────────────────────────────
DB_HOST=your-mysql-host.com
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=ogl_qatar_db

# ── Server ───────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── CORS (comma-separated list of allowed frontend URLs) ─
# In development: http://localhost:8080
# In production: your actual domain
ALLOWED_ORIGINS=https://oneglobalqatar.com,https://www.oneglobalqatar.com,https://oneglobalqatardb.vercel.app/,https://www.oneglobalqatardb.vercel.app/

# ── Admin auth ───────────────────────────────────────────
# ADMIN_PASSWORD_HASH is a bcrypt hash, not the plaintext password.
# Generate one with: node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
# JWT_SECRET should be a long random string, e.g.: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ADMIN_EMAIL=your-admin-email@example.com
ADMIN_PASSWORD_HASH=your_bcrypt_hash
JWT_SECRET=your_random_secret
